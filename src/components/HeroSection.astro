---

---

<section class="relative flex min-h-screen items-center justify-center px-4">
  <!-- Decorative elements -->
  <div
    class="pointer-events-none absolute top-1/4 left-4 h-32 w-32 rounded-full bg-apricot-light/30 blur-3xl"
  >
  </div>
  <div
    class="pointer-events-none absolute right-4 bottom-1/4 h-32 w-32 rounded-full bg-magenta-light/20 blur-3xl"
  >
  </div>

  <div class="relative flex animate-fade-in-up flex-col items-center text-center">
    <!-- Large TWICE Logo -->
    <div class="relative mb-8">
      <img src="/images/logo.webp" alt="Know TWICE logo" width={150} height={150} />
    </div>

    <!-- Headline -->
    <h1 class="mb-4 text-5xl font-bold md:text-7xl">
      <span class="bg-gradient-to-r from-magenta to-apricot bg-clip-text text-transparent">
        Know TWICE
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="mb-8 max-w-lg text-lg text-charcoal/70 md:text-xl">
      Your complete guide to the K-pop girl group TWICE
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col gap-4 sm:flex-row">
      <a
        href="/members"
        class="group hover:shadow-card-hover rounded-full bg-gradient-to-r from-magenta to-magenta-dark px-8 py-3 font-medium text-white transition-all duration-300 hover:scale-105"
      >
        <span class="flex items-center gap-2">
          Meet the Members
          <svg
            class="h-4 w-4 transition-transform group-hover:translate-x-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
            ></path>
          </svg>
        </span>
      </a>
      <a
        href="/discography"
        class="group hover:shadow-card rounded-full border-2 border-magenta/30 bg-white/50 px-8 py-3 font-medium text-magenta transition-all duration-300 hover:border-magenta hover:bg-white"
      >
        <span class="flex items-center gap-2">
          Explore Discography
          <svg
            class="h-4 w-4 transition-transform group-hover:translate-x-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
            ></path>
          </svg>
        </span>
      </a>
    </div>
  </div>
</section>
