---
import { MEMBERS } from '../const/members'
import { DISCOGRAPHY } from '../const/discography'
---

<section class="container mx-auto px-4 py-16 md:py-24">
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
    <!-- Members Card -->
    <a
      href="/members"
      class="group glass shadow-card hover:shadow-card-hover rounded-2xl p-6 transition-all duration-300 hover:scale-[1.02]"
    >
      <div class="flex flex-col gap-4">
        <!-- Member avatars -->
        <div class="flex -space-x-3">
          {
            MEMBERS.map((member) => (
              <img
                src={member.image.src}
                alt={member.name}
                width={48}
                height={48}
                class="h-12 w-12 rounded-full border-2 border-white object-cover shadow-sm"
              />
            ))
          }
        </div>

        <div>
          <h2 class="text-xl font-bold text-magenta">Members</h2>
          <p class="mt-1 text-charcoal/70">Get to know each member.</p>
        </div>

        <div class="flex items-center gap-2 text-sm font-medium text-magenta">
          Explore
          <svg
            class="h-4 w-4 transition-transform group-hover:translate-x-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
            ></path>
          </svg>
        </div>
      </div>
    </a>

    <!-- Discography Card -->
    <a
      href="/discography"
      class="group glass shadow-card hover:shadow-card-hover rounded-2xl p-6 transition-all duration-300 hover:scale-[1.02]"
    >
      <div class="flex flex-col gap-4">
        <!-- Album covers -->
        <div class="flex -space-x-2">
          {
            DISCOGRAPHY.slice(0, 4).map((album) => (
              <img
                src={album.image.src}
                alt={album.name}
                width={56}
                height={56}
                class="h-14 w-14 rounded-lg border-2 border-white object-cover shadow-sm"
              />
            ))
          }
        </div>

        <div>
          <h2 class="text-xl font-bold text-magenta">Discography</h2>
          <p class="mt-1 text-charcoal/70">Explore albums, singles, and tracks.</p>
        </div>

        <div class="flex items-center gap-2 text-sm font-medium text-magenta">
          Explore
          <svg
            class="h-4 w-4 transition-transform group-hover:translate-x-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
            ></path>
          </svg>
        </div>
      </div>
    </a>
  </div>
</section>
