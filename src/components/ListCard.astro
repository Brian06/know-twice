---
import type { TSong } from '../types/members';
import MusicPlatformLinks from './MusicPlatformLinks.astro';

export interface Props {
  icon: any;
  title: string;
  items: string[] | TSong[];
  class?: string;
}

const { icon: Icon, title, items, class: className } = Astro.props;

const isSong = (item: string | TSong): item is TSong => {
  return (
    typeof item === 'object' &&
    item !== null &&
    'title' in item &&
    'links' in item
  );
};
---

<div
  class={`glass rounded-2xl p-5 shadow-card hover:shadow-card-hover transition-shadow duration-300 ${className || ''}`}
  data-testid={`list-card-${title.toLowerCase().replace(' ', '-')}`}
>
  <div class="flex items-center gap-3 mb-4">
    <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-gradient-to-br from-magenta-light/30 to-apricot-light/30 text-magenta">
      <Icon width={18} height={18} />
    </div>
    <p class="text-magenta font-bold text-lg tracking-wide">{title}</p>
  </div>

  <ul class="space-y-2.5 ml-1">
    {
      items.map((item) => (
        <li class="flex items-start gap-2">
          <span class="text-magenta/50 mt-1.5">•</span>
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-charcoal/80">{isSong(item) ? item.title : item}</span>

            {isSong(item) && (
              <MusicPlatformLinks links={item.links} songTitle={item.title} />
            )}
          </div>
        </li>
      ))
    }
  </ul>
</div>
