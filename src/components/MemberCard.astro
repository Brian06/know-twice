---
import { Image } from 'astro:assets'
import { MEMBERS } from '../const/members'
import type { TMemberId } from '../types/members'

export interface Props {
  id: TMemberId
  extraClasses?: string
}

const { id, extraClasses = '' } = Astro.props
const member = MEMBERS.find((member) => member.id === id)
if (!member) throw new Error(`Member with id ${id} not found`)

const memberColors: Record<string, string> = {
  nayeon: '#7dd4f0',
  jeongyeon: '#b8d06a',
  momo: '#ffb8c4',
  sana: '#8c8fc9',
  jihyo: '#f5b860',
  mina: '#5fb8b5',
  dahyun: '#d4d2c4',
  chaeyoung: '#e0132c',
  tzuyu: '#016cba',
}
const borderColor = memberColors[id] || '#ff5fa2'
---

<a
  href={`/members/${id}`}
  class={`js-member-card w-16 h-16 xs:w-20 xs:h-20 sm:w-24 sm:h-24 md:w-24 md:h-24 lg:w-28 lg:h-28 group overflow-hidden rounded-full border-2 border-charcoal/20 bg-charcoal/5 hover:border-[var(--member-color)] hover:bg-[var(--member-color)] hover:cursor-pointer transition-all duration-300 ${extraClasses}`}
  data-id={id}
  style={`--member-color: ${borderColor}`}
>
  <Image
    src={member.image}
    width={128}
    height={128}
    widths={[64, 80, 96, 112, 128]}
    sizes="(max-width: 475px) 64px, (max-width: 640px) 80px, (max-width: 1024px) 96px, 112px"
    class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
    alt={`${member.name} - TWICE member`}
    fetchpriority="high"
    loading="eager"
  />
</a>

<script>
  import { $, $$ } from '../utils/dom-selector'

  let timeoutToChangeMember: ReturnType<typeof setTimeout> | null = null
  let selectedMemberIdMobile: string | null = null

  const isMobile = () => {
    return window.matchMedia('(max-width: 768px)').matches
  }

  const triggerHoverEffect = (id: string) => {
    const event = new CustomEvent('member-card-hover', {
      detail: { id },
    })
    document.dispatchEvent(event)
  }

  const handleFirstTap = (e: Event, card: Element, id: string) => {
    e.preventDefault()

    selectedMemberIdMobile = id
    triggerHoverEffect(id)
  }

  const clearMobileSelection = () => {
    if (!selectedMemberIdMobile) return
    selectedMemberIdMobile = null

    const event = new CustomEvent('member-card-exit')
    document.dispatchEvent(event)
  }

  const mouseEnterDesktop = (card: Element) => {
    card.addEventListener('mouseenter', () => {
      if (isMobile()) return

      if (timeoutToChangeMember) {
        clearTimeout(timeoutToChangeMember)
      }

      const id = card.getAttribute('data-id')

      if (id) {
        triggerHoverEffect(id)
      }
    })
  }

  const mouseLeaveDesktop = (card: Element) => {
    card.addEventListener('mouseleave', () => {
      if (isMobile()) return

      timeoutToChangeMember = setTimeout(() => {
        const event = new CustomEvent('member-card-exit')
        document.dispatchEvent(event)
      }, 500)
    })
  }

  const handleMobileTouch = (card: Element) => {
    card.addEventListener('click', (e) => {
      if (!isMobile()) return

      const id = card.getAttribute('data-id')
      if (!id) return

      if (selectedMemberIdMobile !== id) {
        handleFirstTap(e, card, id)
        return
      }
    })
  }

  const handleTouchOutside = (card: Element) => {
    document.addEventListener('touchstart', (e) => {
      if (!isMobile()) return

      const target = e.target as Element
      const clickedCard = target.closest('.js-member-card')

      if (!clickedCard && selectedMemberIdMobile) {
        clearMobileSelection()
      }
    })
  }

  document.addEventListener('astro:page-load', () => {
    const memberCards = $$('.js-member-card')
    selectedMemberIdMobile = null

    if (memberCards) {
      memberCards.forEach((card) => {
        mouseEnterDesktop(card)
        mouseLeaveDesktop(card)
        handleMobileTouch(card)
        handleTouchOutside(card)
      })
    }
  })
</script>
