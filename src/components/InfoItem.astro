---
import LinkIcon from '../assets/link.svg'

export interface Props {
  icon?: any
  label: string
  value?: string
  link?: string
  colorClass?: string
  class?: string
}

const { icon: Icon, label, value, link, colorClass, class: className } = Astro.props

const isFullLink = link && !value
---

{
  isFullLink ? (
    <a
      href={link}
      target="_blank"
      rel="noopener noreferrer"
      class:list={[
        'group shadow-card hover:shadow-card-hover flex items-center justify-between rounded-xl bg-white/80 p-4 transition-all duration-300 hover:bg-white',
        className,
      ]}
      data-testid={`info-item-${label.toLowerCase().replace(':', '')}`}
    >
      <div class="flex items-center gap-3">
        {Icon && (
          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-apricot-lightest text-magenta">
            <Icon width={16} height={16} />
          </div>
        )}
        <span class="text-charcoal/70">{label}</span>
      </div>
      <LinkIcon
        width={14}
        height={14}
        class="text-charcoal/40 transition-colors group-hover:text-magenta"
      />
    </a>
  ) : (
    <div
      class:list={[
        'shadow-card flex items-center justify-between rounded-xl bg-white/80 p-4 transition-all duration-300 hover:bg-white',
        className,
      ]}
      data-testid={`info-item-${label.toLowerCase().replace(':', '')}`}
    >
      <div class="flex items-center gap-3">
        {Icon && (
          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-apricot-lightest text-magenta">
            <Icon width={16} height={16} />
          </div>
        )}
        <span class="text-charcoal/70">{label}</span>
      </div>

      {link ? (
        <a
          href={link}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 font-medium text-magenta transition-colors duration-200 hover:underline"
        >
          {value}
          <LinkIcon width={14} height={14} />
        </a>
      ) : (
        <div class="flex items-center gap-2">
          <span class="font-medium text-charcoal">{value}</span>
          {label === 'Color:' && (
            <div class={`h-4 w-4 rounded-full shadow-sm ring-2 ring-white ${colorClass}`} />
          )}
        </div>
      )}
    </div>
  )
}
