---
import Badge from './Badge.astro'

export interface Props {
  href: string
  text: string
  active?: boolean
  badge?: {
    text: string
    variant?: 'working' | 'new' | 'coming-soon'
    size?: 'sm' | 'xs'
  }
}

const { href, text, badge, active = false } = Astro.props
---

<div class="relative">
  <a
    href={href}
    class:list={[
      'group relative inline-flex items-center justify-center py-2 text-base tracking-wider uppercase transition-all duration-300',
      active ? 'font-medium text-magenta' : 'text-charcoal/80 hover:text-magenta',
    ]}
  >
    <span class="relative">
      {text}
      <span
        class:list={[
          'absolute -bottom-1 left-0 h-0.5 origin-left bg-gradient-to-r from-magenta to-apricot transition-transform duration-300',
          active ? 'scale-x-100' : 'scale-x-0 group-hover:scale-x-100',
        ]}></span>
    </span>
  </a>
  {badge && <Badge text={badge.text} variant={badge.variant} />}
</div>
