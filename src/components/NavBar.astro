---
import { Image } from 'astro:assets';
import NavLink from './NavLink.astro';
---

<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" data-nav>
  <div class="mx-auto max-w-7xl px-4 md:px-8">
    <div class="flex items-center justify-center py-3 md:py-4">
      <!-- Left: Members -->
      <div class="flex items-center gap-6 md:gap-8">
        <NavLink href="/members" text="Members" />
      </div>

      <!-- Center logo -->
      <a href="/" class="group relative flex items-center justify-center mx-8">
        <div class="relative h-12 w-12 md:h-14 md:w-14">
          <Image
            class="relative transition-transform duration-300 group-hover:scale-105"
            src="/images/logo.webp"
            alt="Twice"
            width={56}
            height={56}
            fetchpriority="high"
            loading="eager"
          />
        </div>
      </a>

      <!-- Right: Albums -->
      <div class="flex items-center gap-6 md:gap-8">
        <NavLink href="/discography" text="Albums" />
      </div>
    </div>
  </div>
</nav>

<style>
  nav {
    animation: nav-slide-down 0.6s ease-out both;
  }

  @keyframes nav-slide-down {
    0% {
      opacity: 0;
      transform: translateY(-100%);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  nav {
    background: linear-gradient(to bottom, rgba(253, 248, 243, 0.95), rgba(253, 248, 243, 0.8));
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 95, 162, 0.1);
  }

  @media (max-width: 640px) {
    nav {
      background: linear-gradient(to bottom, rgba(253, 248, 243, 0.98), rgba(253, 248, 243, 0.95));
    }
  }
</style>

<script>
  import { $, $$ } from '../utils/dom-selector';
  
  let lastScroll = 0;
  const nav = $('nav[data-nav]');
  
  const handleScroll = () => {
    const currentScroll = window.scrollY;
    
    if (nav) {
      if (currentScroll > 100) {
        nav.style.background = 'linear-gradient(to bottom, rgba(253, 248, 243, 0.98), rgba(253, 248, 243, 0.95))';
        nav.style.boxShadow = '0 4px 30px rgba(0, 0, 0, 0.08)';
        nav.style.borderBottomColor = 'rgba(255, 95, 162, 0.2)';
      } else {
        nav.style.background = 'linear-gradient(to bottom, rgba(253, 248, 243, 0.95), rgba(253, 248, 243, 0.8))';
        nav.style.boxShadow = 'none';
        nav.style.borderBottomColor = 'rgba(255, 95, 162, 0.1)';
      }
    }
    
    lastScroll = currentScroll;
  };

  document.addEventListener('scroll', handleScroll, { passive: true });
</script>
