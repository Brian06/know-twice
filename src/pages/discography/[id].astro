---
import Layout from '../../layouts/Layout.astro'
import { DISCOGRAPHY } from '../../const/discography'
import type { GetStaticPaths } from 'astro'
import type { TDiscography } from '../../types/discography'
import { Image } from 'astro:assets'
import InfoItem from '../../components/InfoItem.astro'
import Spotify from '../../assets/music-platforms/spotify.svg'
import AppleMusic from '../../assets/music-platforms/apple-music.svg'
import YouTubeMusic from '../../assets/music-platforms/youtube-music.svg'

const { id } = Astro.params as { id: TDiscography['id'] }
const discography = DISCOGRAPHY.find((discography) => discography.id === id)
if (!discography) return Astro.redirect('/404')

export const getStaticPaths = (() => {
  return DISCOGRAPHY.map((discography) => ({
    params: { id: discography.id },
  }))
}) satisfies GetStaticPaths

const formatType = (type: string) => {
  return type
    .split('-')
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ')
}

const formatMarket = (market: string) => {
  return market.charAt(0).toUpperCase() + market.slice(1)
}

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  })
}
---

<Layout
  title={`${discography.name} - TWICE Discography | Know TWICE`}
  description={`${discography.name} is a ${discography.types.join(' and ')} album by TWICE. Discover the songs, videos, and more about ${discography.name}.`}
  canonical={`https://www.knowtwice.com/discography/${discography.id}`}
  schemaType="CollectionPage"
  schemaData={discography}
>
  <div class="min-h-screen">
    <div class="container mx-auto px-4 pt-28 md:pt-32">
      <div class="mx-auto max-w-4xl">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 md:gap-8">
          <!-- Left Column: Album Art + Listen Now -->
          <div class="flex flex-col items-center gap-6 md:items-start">
            <div class="shadow-card-hover w-64 overflow-hidden rounded-2xl md:w-72">
              <Image
                src={discography.image}
                width={480}
                height={480}
                widths={[256, 320, 480]}
                sizes="(max-width: 768px) 256px, 320px"
                alt={discography.name}
                class="aspect-square object-cover"
              />
            </div>

            <div class="w-full max-w-xs">
              <h2 class="mb-4 text-xl font-bold">Listen Now</h2>
              <div class="flex flex-col gap-2">
                <InfoItem
                  icon={Spotify}
                  label="Spotify"
                  value=""
                  link={`https://open.spotify.com/search/${encodeURIComponent(discography.name + ' TWICE')}`}
                />
                <InfoItem
                  icon={AppleMusic}
                  label="Apple Music"
                  value=""
                  link={`https://music.apple.com/search?term=${encodeURIComponent(discography.name + ' TWICE')}`}
                />
                <InfoItem
                  icon={YouTubeMusic}
                  label="YouTube Music"
                  value=""
                  link={`https://music.youtube.com/search?q=${encodeURIComponent(discography.name + ' TWICE')}`}
                />
              </div>
            </div>
          </div>

          <!-- Right Column: Album Info + Tracklist -->
          <div class="flex flex-col gap-4">
            <div>
              <h1 class="mb-4 text-4xl font-bold text-magenta italic md:text-5xl">
                {discography.name.toUpperCase()}
              </h1>

              <div class="mb-4 flex flex-wrap gap-2">
                {
                  discography.types.map((type) => (
                    <span class="rounded-full bg-magenta px-4 py-1 text-sm font-medium text-white">
                      {formatType(type)}
                    </span>
                  ))
                }
                <span
                  class="rounded-full border border-gray-400 px-4 py-1 text-sm font-medium text-gray-600"
                >
                  {formatMarket(discography.market)}
                </span>
              </div>

              <p class="text-lg text-magenta">
                Released: {formatDate(discography.releaseDate)}
              </p>
            </div>

            <div>
              <h2 class="mb-4 text-2xl font-bold">Tracklist</h2>
              <div class="flex flex-col gap-2">
                {
                  discography.songs.map((song, index) => (
                    <InfoItem
                      label={String(index + 1).padStart(2, '0')}
                      value={song.title}
                      link={song.link}
                      class="bg-white/80"
                    />
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
