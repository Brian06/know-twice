---
import Layout from '../../layouts/Layout.astro'
import DiscographyFilters from '../../components/Preact/DiscographyFilters'
import GoToTop from '../../components/GoToTop.astro'
---

<Layout
  title="TWICE Discography"
  description="TWICE's complete discography, including all albums, singles, and digital releases."
>
  <div class="container mx-auto px-4 py-16 md:py-32">
    <h1 class="mb-8 text-center text-4xl font-bold text-magenta md:mb-16">Discography</h1>
    <DiscographyFilters client:load />
  </div>
  <GoToTop />
</Layout>
